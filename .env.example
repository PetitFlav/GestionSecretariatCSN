# Base de données Supabase
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# Session (générer avec: openssl rand -base64 32)
SESSION_SECRET="changer-cette-valeur-par-une-chaine-aleatoire-longue"

# URL de l'application (Vercel ou localhost)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SMTP (à configurer plus tard)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="secretariat@csn.fr"

# Clé de chiffrement AES-256 des données personnelles (email, DDN, adresse)
# Générer avec: openssl rand -base64 32
ENCRYPTION_KEY="changer-cette-valeur-par-une-cle-aleatoire-32-chars"

# Resend — envoi emails (remplace SMTP, gratuit jusqu'à 3000/mois)
# Créer un compte sur resend.com puis générer une clé API
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Email expéditeur (doit être vérifié dans Resend)
SMTP_FROM="secretariat@csn.fr"

# Corps de l'email d'attestation (optionnel — utilise le template par défaut si absent)
# Variables : {prenom} {nom} {saison}
EMAIL_BODY_TEMPLATE="Bonjour {prenom},\n\nVeuillez trouver ci-joint votre attestation de paiement pour la saison {saison}.\n\nCordialement,\nLe secrétariat du Centre Subaquatique Nantais"
