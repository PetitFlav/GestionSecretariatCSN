generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Saison {
  id                String             @id @default(cuid())
  label             String             @unique
  isActive          Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  dateDebut         String
  dateExpireLicence String
  dateFin           String
  adherents         Adherent[]
  attestationEmails AttestationEmail[]
  impressions       Impression[]
  rappelsCaci       RappelCaci[]
  validations       ValidationFFESSM[]

  @@map("saisons")
}

model Adherent {
  id                String             @id @default(cuid())
  saisonId          String
  nom               String
  prenom            String
  montant           String?
  dateExpiration    String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  adresseDesync     Boolean            @default(false)
  adresseEnc        String?
  civilite          String?
  codePostalEnc     String?
  dateNaissanceEnc  String?
  datePaiement      String?
  emailEnc          String?
  ffessmId          String?
  licence           String?
  villeEnc          String?
  caci              String?
  passager          Boolean            @default(false)
  section           String?
  saison            Saison             @relation(fields: [saisonId], references: [id], onDelete: Cascade)
  attestationEmails AttestationEmail[]
  impressions       Impression[]
  rappelsCaci       RappelCaci[]
  validation        ValidationFFESSM?

  @@unique([saisonId, nom, prenom])
  @@index([saisonId])
  @@index([nom, prenom])
  @@map("adherents")
}

model Impression {
  id          String      @id @default(cuid())
  adherentId  String
  saisonId    String
  zplChecksum String?
  status      PrintStatus @default(PRINTED)
  printedAt   DateTime    @default(now())
  adherent    Adherent    @relation(fields: [adherentId], references: [id], onDelete: Cascade)
  saison      Saison      @relation(fields: [saisonId], references: [id], onDelete: Cascade)

  @@index([adherentId, saisonId])
  @@index([saisonId])
  @@index([status, printedAt])
  @@map("impressions")
}

model AttestationEmail {
  id         String   @id @default(cuid())
  adherentId String
  saisonId   String
  email      String?
  sentAt     DateTime @default(now())
  adherent   Adherent @relation(fields: [adherentId], references: [id], onDelete: Cascade)
  saison     Saison   @relation(fields: [saisonId], references: [id], onDelete: Cascade)

  @@index([adherentId, saisonId])
  @@index([sentAt])
  @@map("attestation_emails")
}

model ValidationFFESSM {
  id            String       @id @default(cuid())
  adherentId    String       @unique
  saisonId      String
  statut        StatutFFESSM @default(NON_SOUMIS)
  validateur    String?
  updatedAt     DateTime     @updatedAt
  adresseEnc    String?
  codePostalEnc String?
  villeEnc      String?
  adherent      Adherent     @relation(fields: [adherentId], references: [id], onDelete: Cascade)
  saison        Saison       @relation(fields: [saisonId], references: [id], onDelete: Cascade)

  @@index([saisonId, statut])
  @@map("validations_ffessm")
}

model User {
  id               String          @id @default(cuid())
  firstName        String          @default("")
  lastName         String          @default("")
  email            String          @unique
  passwordHash     String          @default("")
  role             UserRole        @default(USER)
  status           UserStatus      @default(PENDING)
  setupToken       String?
  setupTokenExpiry DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  smtpConfig       UserSmtpConfig?

  @@map("users")
}

model UserSmtpConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  provider    String?
  hostEnc     String?
  portEnc     String?
  secureEnc   String?
  userEnc     String?
  passwordEnc String?
  fromEnc     String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_smtp_configs")
}

model RappelCaci {
  id         String   @id @default(cuid())
  adherentId String
  saisonId   String
  email      String?
  sentAt     DateTime @default(now())
  adherent   Adherent @relation(fields: [adherentId], references: [id], onDelete: Cascade)
  saison     Saison   @relation(fields: [saisonId], references: [id], onDelete: Cascade)

  @@index([adherentId])
  @@index([saisonId])
  @@map("rappels_caci")
}

enum PrintStatus {
  PRINTED
  SIMULATED
}

enum StatutFFESSM {
  VALIDE
  EN_ATTENTE
  NON_SOUMIS
}

enum UserRole {
  USER
  ADMIN
  SUPERUSER
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}
